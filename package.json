{
  "name": "puerto-rico",
  "version": "0.1.0",
  "description": "Cyfrowa wersja gry Puerto Rico - backend (TypeScript)",
  "type": "module",
  "main": "electron-main.cjs",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build:app": "vite build",
    "check": "tsc --noEmit",
    "build": "tsc",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "server": "tsx server/server.ts",
    "dist": "npm run build:app && electron-builder --win portable",
    "build:html": "vite build --config vite.config.singlefile.ts"
  },
  "build": {
    "appId": "pl.puertorico.game",
    "productName": "Puerto Rico",
    "electronDist": "./node_modules/electron/dist",
    "directories": {
      "output": "dist-exe"
    },
    "files": [
      "dist/**/*",
      "electron-main.cjs"
    ],
    "win": {
      "target": "portable"
    }
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.5.10",
    "@vitejs/plugin-react": "^6.0.2",
    "electron": "^42.3.3",
    "electron-builder": "^26.15.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vite": "^8.0.16",
    "vite-plugin-singlefile": "^2.3.3",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "express": "^4.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "ws": "^8.18.0"
  }
}
